// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String       @id @default(cuid())
  name              String
  email             String       @unique
  phone             String?
  googleId          String?      @unique
  appleId           String?      @unique
  image             String?
  password          String?
  dateOfBirth       DateTime?
  emailVerified     DateTime?
  verificationToken String?      @unique
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  bookings          Booking[]
  loyaltyCard       LoyaltyCard?
  reviews           Review[]
  notes             CustomerNote[]
  referredById      String?      // ID of the User who referred this user
  referredBy        User?        @relation("Referrals", fields: [referredById], references: [id])
  referrals         User[]       @relation("Referrals")
  chatConversations ChatConversation[]
  blogComments      BlogComment[]

  @@map("users")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  @@map("admin_users")
}

model Service {
  id           String    @id @default(cuid())
  name         String
  category     String
  priceFrom    Float
  priceLabel   String    // e.g. "From $65" or "From $65 & up"
  description  String?
  imageUrl     String?
  isActive     Boolean   @default(true)
  displayOrder Int       @default(0)
  bookings     Booking[]
  createdAt    DateTime  @default(now())

  @@map("services")
}

model Booking {
  id                   String        @id @default(cuid())
  userId               String?
  user                 User?         @relation(fields: [userId], references: [id])
  guestName            String?
  guestEmail           String?
  guestPhone           String?
  serviceId            String
  service              Service       @relation(fields: [serviceId], references: [id])
  additionalServiceIds String?       // comma-separated extra service IDs
  preferredDate        String
  preferredTime        String
  notes                String?
  inspoImageUrls       String[]      // Array of uploaded inspo image URLs
  status               BookingStatus @default(PENDING)
  stampAwarded         Boolean       @default(false)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  notifications        NotificationLog[]
  review               Review?
  reviewToken          ReviewToken?
  discountCode         DiscountCode?

  @@map("bookings")
}

model ReviewToken {
  id           String   @id @default(cuid())
  bookingId    String   @unique
  booking      Booking  @relation(fields: [bookingId], references: [id])
  token        String   @unique
  isFirstVisit Boolean  @default(false)
  used         Boolean  @default(false)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([token])
  @@map("review_tokens")
}

model DiscountCode {
  id           String    @id @default(cuid())
  code         String    @unique
  userId       String?
  customerName String
  bookingId    String    @unique
  booking      Booking   @relation(fields: [bookingId], references: [id])
  isUsed       Boolean   @default(false)
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([code])
  @@map("discount_codes")
}

model LoyaltyCard {
  id                       String     @id @default(cuid())
  userId                   String     @unique
  user                     User       @relation(fields: [userId], references: [id])
  currentStamps            Int        @default(0)
  lifetimeStamps           Int        @default(0)
  spinAvailable            Boolean    @default(false)   // 10-stamp reward: free nail set
  spinsRedeemed            Int        @default(0)
  birthdaySpinAvailable    Boolean    @default(false)   // birthday reward: free spin the wheel
  birthdaySpinGrantedYear  Int?       // year the birthday spin was last granted
  isInsider                Boolean    @default(false)
  referralCode             String?    @unique
  referralRewards          Int        @default(0)
  stamps                   Stamp[]
  referrals                Referral[] @relation("ReferrerCard")
  appleWalletDevices       AppleWalletDevice[]
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  @@map("loyalty_cards")
}

model AppleWalletDevice {
  id                String      @id @default(cuid())
  deviceLibraryId   String
  pushToken         String
  loyaltyCardId     String
  loyaltyCard       LoyaltyCard @relation(fields: [loyaltyCardId], references: [id], onDelete: Cascade)
  createdAt         DateTime    @default(now())

  @@unique([deviceLibraryId, loyaltyCardId])
  @@map("apple_wallet_devices")
}

model Referral {
  id             String      @id @default(cuid())
  referrerId     String      // LoyaltyCard.id of the insider who referred
  referrer       LoyaltyCard @relation("ReferrerCard", fields: [referrerId], references: [id])
  referredUserId String      // User.id of the person who signed up
  bookingId      String?     // filled when the referred user completes a booking
  rewardGiven    Boolean     @default(false)
  createdAt      DateTime    @default(now())

  @@map("referrals")
}

model Stamp {
  id            String      @id @default(cuid())
  loyaltyCardId String
  loyaltyCard   LoyaltyCard @relation(fields: [loyaltyCardId], references: [id])
  bookingId     String?
  earnedAt      DateTime    @default(now())
  note          String?

  @@map("stamps")
}

model Review {
  id         String   @id @default(cuid())
  userId     String?                         // null for scraped/imported reviews
  user       User?    @relation(fields: [userId], references: [id])
  bookingId  String?  @unique                // null for scraped/imported reviews
  booking    Booking? @relation(fields: [bookingId], references: [id])
  rating     Int                             // 1-5
  text       String
  source     String   @default("website")   // "website" | "setmore"
  badge      String?                         // "member" | "insider" | null
  authorName String?                         // populated for scraped reviews
  createdAt  DateTime @default(now())

  @@map("reviews")
}

model NotificationLog {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id])
  type        String   // "sms" | "email"
  event       String   @default("unknown") // "booking_received" | "booking_confirmed" | "booking_rescheduled" | "booking_cancelled" | "stamp_earned"
  recipient   String?  // phone number or email address
  status      String   // "sent" | "failed" | "skipped"
  error       String?  // error message if failed (e.g. "credits_exhausted")
  message     String?  // preview of the message body
  sentAt      DateTime @default(now())

  @@index([bookingId])
  @@index([status])
  @@index([sentAt])
  @@map("notification_logs")
}

model SliderImage {
  id        String   @id @default(cuid())
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("slider_images")
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  tags      String   @default("")
  createdAt DateTime @default(now())

  @@map("gallery_images")
}

model CustomerNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  text      String
  imageUrl  String?
  createdAt DateTime @default(now())

  @@map("customer_notes")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model PageView {
  id        String   @id @default(cuid())
  path      String              // e.g. "/" | "/services" | "/book"
  sessionId String              // random ID per browser session (unique visitor proxy)
  referrer  String?             // document.referrer
  device    String?             // "mobile" | "desktop" | "tablet"
  duration  Int?                // seconds on page (sent on unload)
  createdAt DateTime @default(now())

  @@index([path])
  @@index([sessionId])
  @@index([createdAt])
  @@map("page_views")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  updates     TaskUpdate[]

  @@map("tasks")
}

model TaskUpdate {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  note      String
  createdAt DateTime @default(now())

  @@map("task_updates")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model ChatConversation {
  id        String        @id @default(cuid())
  userId    String?       // Optional user link if logged in
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestName String?       // If unauthenticated guest
  startedAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String           // 'user' | 'assistant' | 'system'
  content        String
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@map("chat_messages")
}

model BlogPost {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?
  content     String
  coverImage  String?
  author      String        @default("JoJany")
  published   Boolean       @default(false)
  seoConfig   String?
  views       Int           @default(0)
  comments    BlogComment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([slug])
  @@map("blog_posts")
}

model BlogComment {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([postId])
  @@map("blog_comments")
}

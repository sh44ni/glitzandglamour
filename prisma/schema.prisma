// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String       @id @default(cuid())
  name              String
  email             String       @unique
  phone             String?
  googleId          String?      @unique
  appleId           String?      @unique
  image             String?
  password          String?
  dateOfBirth       DateTime?
  emailVerified     DateTime?
  verificationToken String?      @unique
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  bookings          Booking[]
  loyaltyCard       LoyaltyCard?
  reviews           Review[]
  notes             CustomerNote[]
  referredById      String?      // ID of the User who referred this user
  referredBy        User?        @relation("Referrals", fields: [referredById], references: [id])
  referrals         User[]       @relation("Referrals")
  chatConversations ChatConversation[]
  blogComments      BlogComment[]
  mobileAuthCodes   MobileAuthCode[]

  @@map("users")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  @@map("admin_users")
}

model Service {
  id           String    @id @default(cuid())
  name         String
  slug         String?   @unique
  category     String
  priceFrom    Float
  priceLabel   String    // e.g. "From $65" or "From $65 & up"
  description  String?
  imageUrl     String?
  ogImageUrl   String?
  seoTitle     String?
  seoDescription String?
  seoKeywords  String?
  longDescription String?
  benefits     String?
  faqs         Json?
  durationMins Int?
  startingAtPrice Int?
  isActive     Boolean   @default(true)
  displayOrder Int       @default(0)
  bookings     Booking[]
  createdAt    DateTime  @default(now())

  @@map("services")
}

model Booking {
  id                   String        @id @default(cuid())
  userId               String?
  user                 User?         @relation(fields: [userId], references: [id])
  guestName            String?
  guestEmail           String?
  guestPhone           String?
  serviceId            String
  service              Service       @relation(fields: [serviceId], references: [id])
  additionalServiceIds String?       // comma-separated extra service IDs
  preferredDate        String
  preferredTime        String
  notes                String?
  inspoImageUrls       String[]      // Array of uploaded inspo image URLs
  healthIntake         Json?         // Health intake form data (for Facials/Lashes/Waxing)
  status               BookingStatus @default(PENDING)
  stampAwarded         Boolean       @default(false)
  isPromoBooking       Boolean       @default(false)  // April Special 2026
  promoPrice           Int?          // Fixed price advertised (e.g. 45 or 50)
  // Booking origin metadata (captured at time of booking)
  bookingIp            String?
  bookingUserAgent     String?
  bookingCountry       String?
  bookingRegion        String?
  bookingCity          String?
  bookingLatitude      String?
  bookingLongitude     String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  notifications        NotificationLog[]
  review               Review?
  reviewToken          ReviewToken?
  discountCode         DiscountCode?
  staffLogs            StaffBookingLog[]

  @@map("bookings")
}

model StaffBookingLog {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  label     String   @default("")
  text      String
  createdAt DateTime @default(now())

  @@index([bookingId])
  @@map("staff_booking_logs")
}

model ReviewToken {
  id           String   @id @default(cuid())
  bookingId    String   @unique
  booking      Booking  @relation(fields: [bookingId], references: [id])
  token        String   @unique
  isFirstVisit Boolean  @default(false)
  used         Boolean  @default(false)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([token])
  @@map("review_tokens")
}

// For walk-in / manual clients — no booking required
model GuestReviewLink {
  id           String   @id @default(cuid())
  token        String   @unique
  guestName    String
  isFirstVisit Boolean  @default(false)
  used         Boolean  @default(false)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([token])
  @@map("guest_review_links")
}

model DiscountCode {
  id           String    @id @default(cuid())
  code         String    @unique
  userId       String?
  customerName String
  bookingId    String    @unique
  booking      Booking   @relation(fields: [bookingId], references: [id])
  isUsed       Boolean   @default(false)
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([code])
  @@map("discount_codes")
}

model LoyaltyCard {
  id                       String     @id @default(cuid())
  userId                   String     @unique
  user                     User       @relation(fields: [userId], references: [id])
  currentStamps            Int        @default(0)
  lifetimeStamps           Int        @default(0)
  spinAvailable            Boolean    @default(false)   // 10-stamp reward: free nail set
  spinsRedeemed            Int        @default(0)
  birthdaySpinAvailable    Boolean    @default(false)   // birthday reward: free spin the wheel
  birthdaySpinGrantedYear  Int?       // year the birthday spin was last granted
  isInsider                Boolean    @default(false)
  referralCode             String?    @unique
  referralRewards          Int        @default(0)
  stamps                   Stamp[]
  referrals                Referral[] @relation("ReferrerCard")
  appleWalletDevices       AppleWalletDevice[]
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  @@map("loyalty_cards")
}

model AppleWalletDevice {
  id                String      @id @default(cuid())
  deviceLibraryId   String
  pushToken         String
  loyaltyCardId     String
  loyaltyCard       LoyaltyCard @relation(fields: [loyaltyCardId], references: [id], onDelete: Cascade)
  createdAt         DateTime    @default(now())

  @@unique([deviceLibraryId, loyaltyCardId])
  @@map("apple_wallet_devices")
}

model Referral {
  id             String      @id @default(cuid())
  referrerId     String      // LoyaltyCard.id of the insider who referred
  referrer       LoyaltyCard @relation("ReferrerCard", fields: [referrerId], references: [id])
  referredUserId String      // User.id of the person who signed up
  bookingId      String?     // filled when the referred user completes a booking
  rewardGiven    Boolean     @default(false)
  createdAt      DateTime    @default(now())

  @@map("referrals")
}

model Stamp {
  id            String      @id @default(cuid())
  loyaltyCardId String
  loyaltyCard   LoyaltyCard @relation(fields: [loyaltyCardId], references: [id])
  bookingId     String?
  earnedAt      DateTime    @default(now())
  note          String?

  @@map("stamps")
}

model Review {
  id         String   @id @default(cuid())
  userId     String?                         // null for scraped/imported reviews
  user       User?    @relation(fields: [userId], references: [id])
  bookingId  String?  @unique                // null for scraped/imported reviews
  booking    Booking? @relation(fields: [bookingId], references: [id])
  rating     Int                             // 1-5
  text       String
  source     String   @default("website")   // "website" | "setmore"
  badge      String?                         // "member" | "insider" | null
  authorName String?                         // populated for scraped reviews
  createdAt  DateTime @default(now())

  @@map("reviews")
}

model NotificationLog {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id])
  type        String   // "sms" | "email"
  event       String   @default("unknown") // "booking_received" | "booking_confirmed" | "booking_rescheduled" | "booking_cancelled" | "stamp_earned"
  recipient   String?  // phone number or email address
  status      String   // "sent" | "failed" | "skipped"
  error       String?  // error message if failed (e.g. "credits_exhausted")
  message     String?  // preview of the message body
  sentAt      DateTime @default(now())

  @@index([bookingId])
  @@index([status])
  @@index([sentAt])
  @@map("notification_logs")
}

model SliderImage {
  id        String   @id @default(cuid())
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("slider_images")
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  tags      String   @default("")
  createdAt DateTime @default(now())

  @@map("gallery_images")
}

model CustomerNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  text      String
  imageUrl  String?
  createdAt DateTime @default(now())

  @@map("customer_notes")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model PageView {
  id        String   @id @default(cuid())
  path      String              // e.g. "/" | "/services" | "/book"
  sessionId String              // random ID per browser session (unique visitor proxy)
  referrer  String?             // document.referrer
  referrerHost String?          // derived host from referrer
  device    String?             // "mobile" | "desktop" | "tablet"
  duration  Int?                // seconds on page (sent on unload)
  queryString String?           // window.location.search (no leading "?")
  utmSource String?
  utmMedium String?
  utmCampaign String?
  utmTerm String?
  utmContent String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([sessionId])
  @@index([createdAt])
  @@index([referrerHost])
  @@index([utmSource])
  @@index([utmMedium])
  @@index([utmCampaign])
  @@map("page_views")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  updates     TaskUpdate[]

  @@map("tasks")
}

model TaskUpdate {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  note      String
  createdAt DateTime @default(now())

  @@map("task_updates")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model ChatConversation {
  id         String        @id @default(cuid())
  userId     String?       // Optional user link if logged in
  user       User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestName  String?       // If unauthenticated guest
  label      String?       // Auto-set when booking made, e.g. "Booking: Gel Manicure"
  hasBooking Boolean       @default(false)
  startedAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  messages   ChatMessage[]

  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String           // 'user' | 'assistant' | 'system'
  content        String
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@map("chat_messages")
}

model BlogPost {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?
  content     String
  coverImage  String?
  author      String        @default("JoJany")
  published   Boolean       @default(false)
  seoConfig   String?
  tags        String?
  views       Int           @default(0)
  comments    BlogComment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([slug])
  @@map("blog_posts")
}

model BlogComment {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([postId])
  @@map("blog_comments")
}

model MobileAuthCode {
  id        String   @id @default(cuid())
  code      String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("mobile_auth_codes")
}

enum ContractSigningStatus {
  PENDING
  COMPLETED
}

/// Special-events contract lifecycle (draft → sent → client_signed → signed).
enum ContractLifecycleStatus {
  DRAFT
  SENT
  CLIENT_SIGNED
  SIGNED
}

/// Admin-generated link for the Beauty & Event Services client signing flow.
model ContractSigningInvite {
  id               String                @id @default(cuid())
  token            String                @unique
  label            String?
  clientHintName   String?
  clientHintEmail  String?
  expiresAt        DateTime
  status           ContractSigningStatus @default(PENDING)
  completedAt      DateTime?
  referenceCode    String?
  pdfKey           String?
  formData         Json?
  submittedIp      String?
  submittedUa      String?
  createdAt        DateTime              @default(now())

  /// Full studio/admin field set for special-events contracts (null = legacy generic signing link).
  adminPayload           Json?
  /// Client disclosures, initials map, signature metadata (immutable after client_signed).
  clientPayload          Json?
  /// Admin acceptance: retainer received + countersignature (immutable after signed).
  adminFinalizePayload   Json?
  /// Locked HTML snapshot keys in object storage (client phase / optional final HTML).
  executionHtmlKey       String?
  finalExecutionHtmlKey  String?
  /// PDF after client signs (full contract); may be replaced when admin finalizes if regenerated.
  clientPhasePdfKey      String?

  lifecycleStatus       ContractLifecycleStatus @default(DRAFT)
  contractVersion       String                  @default("special-events-v1")
  sentAt                DateTime?
  openedFirstAt         DateTime?
  clientSignedAt        DateTime?
  adminSignedAt         DateTime?
  retainerReceived      Boolean                 @default(false)
  retainerReceivedAt    DateTime?

  auditLogs ContractAuditLog[]

  @@index([token])
  @@index([status])
  @@index([createdAt])
  @@index([lifecycleStatus])
  @@map("contract_signing_invites")
}

model ContractAuditLog {
  id        String                @id @default(cuid())
  inviteId  String
  invite    ContractSigningInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  action    String
  details   Json?
  actorIp   String?
  createdAt DateTime              @default(now())

  @@index([inviteId])
  @@map("contract_audit_logs")
}

/// Lightweight client record auto-created when a special-event contract is finalized (SIGNED).
/// No login — purely for admin reference. Deduplicated by email (primary) or phone (fallback).
model SpecialEventClient {
  id           String   @id @default(cuid())
  name         String
  email        String?
  phone        String?
  linkedUserId String?  // populated when email/phone matches a User who signs up later
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contracts SpecialEventClientContract[]

  @@index([email])
  @@index([phone])
  @@index([linkedUserId])
  @@map("special_event_clients")
}

/// Join table linking a SpecialEventClient to their ContractSigningInvite(s).
model SpecialEventClientContract {
  id        String             @id @default(cuid())
  clientId  String
  client    SpecialEventClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  inviteId  String
  createdAt DateTime           @default(now())

  @@unique([clientId, inviteId])
  @@index([inviteId])
  @@map("special_event_client_contracts")
}

/// Event categories shown on the public Special Events page (admin-managed).
model SpecialEventCategory {
  id              String   @id @default(cuid())
  tag             String                // Short label: "Bridal", "Prom"
  name            String                // Display title: "Weddings & Bridal"
  slug            String?  @unique      // URL slug: "weddings-bridal"
  description     String
  longDescription String?               // Extended copy for individual page
  benefits        String?               // Bullet-point benefits (newline-separated)
  faqs            Json?                 // Array of {q, a} for FAQ section
  imageUrl        String?               // Uploaded card background photo
  pills           String   @default("") // Comma-separated service pills
  wide            Boolean  @default(false)
  gradient        String   @default("linear-gradient(135deg, #2d0f1e, #1A0A10)")
  displayOrder    Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("special_event_categories")
}

/// Service cards shown on the public Special Events page (admin-managed).
model SpecialEventService {
  id           String   @id @default(cuid())
  icon         String                // Emoji or icon key
  title        String
  description  String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("special_event_services")
}

/// Hero section content for the Special Events page (admin-managed, single active row).
model SpecialEventHero {
  id        String   @id @default(cuid())
  eyebrow   String   @default("Vista, CA · Special Events")
  headline  String   @default("Your most beautiful moments, made unforgettable.")
  subtext   String   @default("Bridal parties, quinceañeras, proms, and every celebration in between.")
  imageUrl  String?               // Hero background image
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("special_event_hero")
}

/// Hero slider images for the Special Events page (up to 10, admin-managed).
model SpecialEventHeroImage {
  id        String   @id @default(cuid())
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("special_event_hero_images")
}

/// Admin-managed gallery photos for the Special Events page bento grid.
/// Limited to 12. Each photo has a title + description for SEO popup.
model SpecialEventGalleryPhoto {
  id          String   @id @default(cuid())
  url         String
  title       String   @default("")
  description String   @default("")
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([order])
  @@map("special_event_gallery_photos")
}

/// Inquiry submitted via the Special Events page public form.
model SpecialEventInquiry {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  phone       String
  email       String
  eventType   String
  eventDate   String
  startTime   String?
  guestCount  String
  location    String
  services    String   // JSON array stored as string
  onLocation  String
  inspiration String?
  budget      String?
  referral    String?
  notes       String?
  status      String   @default("new") // "new" | "contacted" | "converted" | "closed"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("special_event_inquiries")
}

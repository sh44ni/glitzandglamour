# =====================================================
# GLITZ & GLAMOUR ADMIN PANEL - ENVIRONMENT CONFIGURATION
# =====================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =====================================================
# SECURITY - CHANGE THESE IN PRODUCTION!
# =====================================================
# Secret key for Flask sessions (generate a random 32+ character string)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# =====================================================
# ADMIN CREDENTIALS - CHANGE THESE!
# =====================================================
# Default admin login credentials
# IMPORTANT: Change these immediately after first login!
ADMIN_EMAIL=admin@glitzandglamour.com
ADMIN_PASSWORD=change-this-password-immediately

# =====================================================
# CORS CONFIGURATION (Optional)
# =====================================================
# Allowed origins for API requests (comma-separated)
# Leave empty to allow all origins, or specify your frontend URL
# Example: https://glitzandglamourstudio.com,https://www.glitzandglamourstudio.com
ALLOWED_ORIGINS=

# Glitz & Glamour Studio - Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# RESEND EMAIL SERVICE
# ===========================================
# Get your API key from: https://resend.com
RESEND_API_KEY=your_resend_api_key_here

# From email address (must be verified in Resend)
# For development, use: onboarding@resend.dev
FROM_EMAIL=onboarding@resend.dev

# ===========================================
# CONTACT CONFIGURATION
# ===========================================
# Email address to receive booking and contact form submissions
CONTACT_EMAIL=glitzandglamourstudio@email.com

# ===========================================
# SITE CONFIGURATION
# ===========================================
# Your site's URL (used for SEO meta tags)
NEXT_PUBLIC_SITE_URL=https://glitzandglamourstudio.com

# ===========================================
# FUTURE: DATABASE CONNECTION
# ===========================================
# Uncomment when ready to migrate from file-based storage
# DATABASE_URL="postgresql://user:password@localhost:5432/glitzglamour"
# or for MongoDB:
# DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/glitzglamour"

# ===========================================
# ADMIN PANEL
# ===========================================
# URL of the admin panel API (Flask backend)
# Development: http://localhost:5000
# Production: https://your-admin-url.onrender.com
NEXT_PUBLIC_ADMIN_URL=http://localhost:5000

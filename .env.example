# =====================================================
# GLITZ & GLAMOUR STUDIO - ENVIRONMENT CONFIGURATION
# =====================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# =====================================================
# ADMIN PANEL INTEGRATION
# =====================================================
# URL of the admin panel API (Flask backend)
# Development: http://localhost:5000
# Production: https://your-admin-app.onrender.com (or your deployed admin URL)
NEXT_PUBLIC_ADMIN_URL=http://localhost:5000

# =====================================================
# SITE CONFIGURATION
# =====================================================
# Your site's URL (used for SEO meta tags)
NEXT_PUBLIC_SITE_URL=https://glitzandglamourstudio.com

# =====================================================
# GLITZ & GLAMOUR STUDIO — ENVIRONMENT CONFIGURATION
# =====================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control!

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://...

# Auth.js secrets
AUTH_SECRET=your-auth-secret-here
ADMIN_JWT_SECRET=your-admin-jwt-secret
AUTH_URL=https://glitzandglamours.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple Sign In
AUTH_APPLE_ID=com.glitzglamour.signin
AUTH_APPLE_SECRET=your-apple-jwt-secret

# Resend Email
RESEND_API_KEY=re_your-primary-key
RESEND_API_KEY_SECONDARY=re_your-secondary-key
RESEND_FROM=info@glitzandglamours.com

# Owner / JoJany contact
OWNER_PHONE_NUMBER=+17602905910
OWNER_NOTIFICATION_ID=info@glitzandglamours.com

# =====================================================
# PINGRAM SMS — Production Plan (2,000 SMS/mo)
# =====================================================
# Secret API key (server-side only — never expose publicly)
PINGRAM_API_KEY=pingram_sk_...
# Public key (used for client-side SDK if needed)
PINGRAM_PUBLIC_KEY=pingram_pk_...
# Account / Environment credentials
PINGRAM_CLIENT_ID=your-client-id
PINGRAM_CLIENT_SECRET=your-client-secret
# Base URL (US region default)
PINGRAM_BASE_URL=https://api.pingram.io
# Your dedicated outbound number (configure in Pingram dashboard)
PINGRAM_FROM_NUMBER=+17609070455

# Admin credentials
ADMIN_EMAIL=info@glitzandglamours.com
ADMIN_PASSWORD=your-admin-password

# MinIO Image Storage (VPS)
MINIO_ENDPOINT=your-vps-ip
MINIO_PORT=9000
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET=glitz-images
MINIO_PUBLIC_URL=http://your-vps-ip:9000

# Google Wallet
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_ISSUER_ID=your-issuer-id

# Groq AI (Review message generation)
GROQ_API_KEY_REVIEWS=gsk_...

# Review token signing secret
REVIEW_TOKEN_SECRET=your-review-token-secret
